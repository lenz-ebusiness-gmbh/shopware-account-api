{
    "name": "lenz/shopware-account-api",
    "description": "Standalone PHP client for the Shopware Account / Store (SBP) API: authentication, plugins, support tickets, provisions and statistics.",
    "type": "library",
    "license": "MIT",
    "keywords": ["shopware", "account", "sbp", "store", "api", "client", "support-tickets", "producer"],
    "authors": [
        {
            "name": "Sebastian Lenz",
            "email": "info@lenz-ebusiness.de"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "php-http/discovery": "^1.19"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "guzzlehttp/guzzle": "^7.8",
        "nyholm/psr7": "^1.8",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.50"
    },
    "suggest": {
        "guzzlehttp/guzzle": "PSR-18 HTTP client + PSR-17 factories implementation",
        "symfony/http-client": "Alternative PSR-18 HTTP client (use with nyholm/psr7 for factories)"
    },
    "autoload": {
        "psr-4": {
            "Lenz\\ShopwareAccountApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lenz\\ShopwareAccountApi\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
